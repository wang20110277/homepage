# Database
POSTGRES_URL=postgresql://dev_user:dev_password@localhost:5432/postgres_dev

# Authentication / App URLs
BETTER_AUTH_SECRET=your-better-auth-secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OIDC Provider Configuration
OIDC_PROVIDER=entra
NEXT_PUBLIC_OIDC_PROVIDER=entra

# Azure Entra ID
ENTRA_CLIENT_ID=entra-client-id
ENTRA_CLIENT_SECRET=entra-client-secret
ENTRA_TENANT_ID=entra-tenant-id
ENTRA_ISSUER=https://login.microsoftonline.com/entra-tenant-id/v2.0

# ADFS
ADFS_CLIENT_ID=adfs-client-id
ADFS_CLIENT_SECRET=adfs-client-secret
ADFS_ISSUER=https://adfs.example.com/adfs
ADFS_AUTHORIZATION_URL=https://adfs.example.com/adfs/oauth2/authorize
ADFS_TOKEN_URL=https://adfs.example.com/adfs/oauth2/token
ADFS_USERINFO_URL=https://adfs.example.com/adfs/userinfo
ADFS_JWKS_URL=https://adfs.example.com/adfs/discovery/keys

# Claims Mapping
ENTRA_ROLE_MAPPINGS={"Global Admin":"admin","User":"user"}
ADFS_ROLE_MAPPINGS={"CN=Admins,OU=Groups,DC=company,DC=com":"admin","CN=Users,OU=Groups,DC=company,DC=com":"user"}

# Session / Feature Flags
SESSION_MAX_AGE=28800
ENABLE_AUDIT_LOGS=false
DEFAULT_USER_ROLE=user

# Local fallback administrator
LOCAL_ADMIN_EMAIL=admin@local.dev
LOCAL_ADMIN_PASSWORD=ChangeMe123!
LOCAL_ADMIN_NAME=Offline Admin

# Google OAuth (legacy mock flow - keep empty if unused)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI Integration via OpenRouter (Optional - for chat functionality)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5-mini

# Optional - for vector search only
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# File storage (optional - if app required file uploads)
BLOB_READ_WRITE_TOKEN=

# Polar payment processing
# Get these from: https://sandbox.polar.sh/dashboard (sandbox) or https://polar.sh/dashboard (production)
POLAR_WEBHOOK_SECRET=polar_
POLAR_ACCESS_TOKEN=polar_

# BFF Layer - External Service Configuration
# Presenton Service (PPT Generation)
PRESENTON_BASE_URL=http://localhost:5000
PRESENTON_TIMEOUT=600000
# Optional: API key if your Presenton service requires authentication
PRESENTON_API_KEY=

# OCR Service (Gradio) - Coming soon
# OCR_BASE_URL=http://localhost:7860
# OCR_TIMEOUT=60000

# Additional services can be added here following the same pattern:
# [SERVICE_NAME]_BASE_URL=
# [SERVICE_NAME]_TIMEOUT=
# [SERVICE_NAME]_API_KEY=

# Open WebUI Integration
OPEN_WEBUI_BASE_URL=https://gpt.luckybruce.com
OPEN_WEBUI_TIMEOUT=30000
OPEN_WEBUI_COMPLETION_TIMEOUT=120000
OPEN_WEBUI_MODEL_CACHE_SECONDS=30
# Optional shared bearer token for Open WebUI (use only if per-user tokens unavailable)
OPEN_WEBUI_SERVICE_TOKEN=
# Optional API key for Open WebUI deployments that require it
OPEN_WEBUI_API_KEY=
